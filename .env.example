# PocketBase Configuration
# See https://pocketbase.io/docs for more info

# Port for PocketBase to listen on (default: 8080)
# Railway sets PORT automatically — override here if needed
PORT=8080

# Encryption key for encrypting app settings (32 hex characters recommended)
# Generate one: openssl rand -hex 16
ENCRYPTION_KEY=

# CORS allowed origins (comma-separated, if you need custom domains)
# ORIGINS=https://app.example.com,https://admin.example.com
